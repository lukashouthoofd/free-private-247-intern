# Secrets template — copy to .env in the repo root, then fill in.   chmod 600 .env
# NEVER commit the real .env (it is in .gitignore). `agent setup` writes keys here for you.
# You only need the ONE key for the provider you picked in config.yaml. The rest are optional.

# --- Your brain (pick one to match config.yaml `model.provider`) ---
GEMINI_API_KEY=AIza...                 # gemini   (free tier — aistudio.google.com)
# OPENAI_API_KEY=sk-...                 # openai
# GROQ_API_KEY=gsk_...                  # groq
# OPENROUTER_API_KEY=sk-or-...          # openrouter
# MISTRAL_API_KEY=...                   # mistral
# ANTHROPIC_API_KEY=sk-ant-...          # anthropic (native API)
# claude-code provider needs NO key here — run `claude setup-token` once instead.
# ollama provider needs NO key (local).

# --- Telegram channel (optional; allow-list goes in config.yaml, not here) ---
# TELEGRAM_BOT_TOKEN=123456789:AA...     # from @BotFather

# --- Email tool (optional; the agent reads + drafts, sending stays human-gated) ---
# EMAIL_IMAP_HOST=imap.example.com
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_ADDRESS=you@example.com
# EMAIL_PASSWORD=app-password           # use a provider app-password, not your login
# EMAIL_SMTP_PORT=465                    # optional, defaults to 465
