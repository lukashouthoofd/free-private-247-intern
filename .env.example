# Secrets template.
# Copy to ~/.hermes/.env and fill in your own values.  chmod 600 ~/.hermes/.env
# NEVER commit the real .env (it is in .gitignore).

# --- Main brain: Gemini (free via aistudio.google.com) ---
GEMINI_API_KEY=AIza...
GOOGLE_API_KEY=AIza...                  # may be the same key

# --- Groq (Whisper voice STT + capable fallback models) ---
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=gsk_...                  # custom-provider auth for the Groq fallback models = your Groq key
OPENROUTER_API_KEY=gsk_...              # same (fallback path)

# --- Telegram (or your chat channel of choice) ---
TELEGRAM_BOT_TOKEN=123456789:AA...      # from @BotFather
TELEGRAM_ALLOWED_USERS=123456789        # your numeric id (via @userinfobot) — ONLY you
TELEGRAM_HOME_CHANNEL=123456789

# --- Ollama (local, no key needed) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_NUM_CTX=65536

# --- Coding agent (optional: heavy work via a metered CLI) ---
# CLAUDE_CODE_OAUTH_TOKEN=...           # generate with: claude setup-token
# CLAUDE_DAYCAP=20                       # max coding-agent runs/day (protects the metered pool)

# --- Optional overrides ---
# CRM_DB=~/.hermes/data/leads.db          # relocate the CRM SQLite database (optional)
